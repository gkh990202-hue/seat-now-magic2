# Copy to .env and fill from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_or_sb_publishable_key
# Optional: bypasses RLS. If omitted, SUPABASE_PUBLISHABLE_KEY is used (requires write RLS policies).
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_sb_secret_key

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_sb_publishable_key

# Optional (not read by app client code)
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
